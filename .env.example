# OpenRouter API Key untuk fitur Screenshot OCR (opsional)
# Atau gunakan Anthropic API key langsung
OPENROUTER_API_KEY=your_api_key_here

# Model OCR (opsional, default: claude-sonnet-4-6)
# OCR_MODEL=claude-sonnet-4-6

# Password login (opsional, kosongkan untuk akses tanpa login)
# AUTH_PASSWORD=your_password_here

# Database (opsional, default: SQLite lokal)
# Set untuk PostgreSQL: postgresql://user:pass@host:5432/dbname
# DATABASE_URL=

# Scheduler background jobs (default: 1 = aktif untuk lokal)
# Set 0 untuk Render/cloud agar on-demand saja
# USE_SCHEDULER=1
